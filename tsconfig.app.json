{
  "extends": "./tsconfig.json",
  "include": [
    "App.tsx",
    "index.tsx",
    "constants.ts",
    "types.ts",
    "vite.config.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "supabase/**/*",
    "api/**/*",
    "functions/**/*",
    "scripts/**/*",
    "server/**/*",
    "node_modules",
    "dist"
  ]
}
